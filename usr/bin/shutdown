#!/bin/sh
# RezzOS Shutdown Command Interface

RED='\033[1;31m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
BLUE='\033[1;34m'
CYAN='\033[1;36m'
NC='\033[0m'

show_usage() {
    echo -e "${BLUE}=== RezzOS Shutdown Utility (shutdown) ===${NC}"
    echo "Usage: shutdown [OPTION]... [TIME]"
    echo ""
    echo "Options:"
    echo "  -h, -P, --poweroff   Power off the system (default)"
    echo "  -r, --reboot         Reboot the system"
    echo "  -s, --suspend        Suspend / sleep mode (instant sleep)"
    echo "  -z, -H, --hibernate  Hibernate state to swap disk"
    echo "  --help               Show this help message"
    echo ""
    echo "Time format:"
    echo "  now                  Bring system down immediately (default)"
    echo "  +m                   Wait m minutes before bringing system down"
    echo ""
    echo "Examples:"
    echo "  shutdown"
    echo "  shutdown -h now"
    echo "  shutdown -r now"
    echo "  shutdown -s"
    echo "  shutdown -z"
}

ACTION="poweroff"
DELAY=0

while [ $# -gt 0 ]; do
    case "$1" in
        -h|--poweroff|-P)
            ACTION="poweroff"
            shift
            ;;
        -r|--reboot)
            ACTION="reboot"
            shift
            ;;
        -s|--suspend)
            ACTION="suspend"
            shift
            ;;
        -z|-H|--hibernate)
            ACTION="hibernate"
            shift
            ;;
        now)
            DELAY=0
            shift
            ;;
        --help)
            show_usage
            exit 0
            ;;
        +[0-9]*)
            DELAY=$(echo "$1" | tr -d '+')
            shift
            ;;
        [0-9]*)
            DELAY="$1"
            shift
            ;;
        *)
            echo -e "${YELLOW}Unknown option or argument: $1${NC}"
            shift
            ;;
    esac
done

if [ "$DELAY" -gt 0 ] 2>/dev/null; then
    echo -e "${YELLOW}[RezzOS] System will $ACTION in $DELAY minute(s). Press Ctrl+C to cancel.${NC}"
    sleep $((DELAY * 60))
fi

exec /usr/bin/system-shutdown "$ACTION"
