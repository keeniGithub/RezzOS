#!/bin/sh

clear
echo ""
echo "     ____                 ____  _____"
echo "    / __ \___  ________  / __ \/ ___/"
echo "   / /_/ / _ \/_  /_  / / / / /\__ \\"
echo "  / _, _/  __/ / /_/ /_/ /_/ /___/ /"
echo " /_/ |_|\___/ /___/___/\____//____/"
echo ""
echo "  OS:       RezzOS (Linux + BusyBox)"
echo "  Kernel:   $(uname -r)"
echo "  Uptime:   $(cat /proc/uptime | cut -d. -f1 | awk '{printf "%dm", $1/60}')"
echo "  Shell:    /bin/sh"
echo "  Host:     $(hostname)"
echo ""
echo "  Disk:     $(df -h /mnt/disk | tail -1 | awk '{print $3" / "$2}')"
echo "  Memory:   $(free -m | grep Mem | awk '{print $3" MB / "$2" MB"}')"
echo "  Network:  $(ifconfig eth0 | grep 'inet ' | awk '{print $2}')"
echo "  Files:    $(ls /mnt/disk/ | wc -l) in /mnt/disk"
echo ""
