            ;;
        *)
            chmod +x "/mnt/disk/${FILE}" 2>/dev/null
            echo "   вЪ° –Т–Њ–Ј–Љ–Њ–ґ–љ–Њ –Є—Б–њ–Њ–ї–љ—П–µ–Љ—Л–є"
