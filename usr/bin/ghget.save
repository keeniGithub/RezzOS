            echo "   –†–∞—Б–њ–∞–Ї–Њ–≤–∞—В—М: tar -xjf /mnt/disk/${FILE} -C /mnt/disk/"
            ;;
        *.tar.xz|*.txz)
            echo "   рЯУ¶ –Р—А—Е–Є–≤ tar.xz"
            echo "   –†–∞—Б–њ–∞–Ї–Њ–≤–∞—В—М: tar -xJf /mnt/disk/${FILE} -C /mnt/disk/"
            ;;
