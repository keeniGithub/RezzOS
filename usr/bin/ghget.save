    echo "вЬЕ –У–Њ—В–Њ–≤–Њ! (${size}) -> /mnt/disk/${FILE}"
    
    # –Ю–њ—А–µ–і–µ–ї—П–µ–Љ —В–Є–њ –Є –і–∞—С–Љ –њ–Њ–і—Б–Ї–∞–Ј–Ї–Є
    case "$FILE" in
