#!/bin/sh
PKG_DIR="/mnt/disk/packages"
REPO="https://dl-cdn.alpinelinux.org/alpine/v3.20/main/x86_64"
COMMUNITY="https://dl-cdn.alpinelinux.org/alpine/v3.20/community/x86_64"

usage() {
    echo "Usage: pkg <install|search|list> [package]"
}

find_pkg() {
    NAME="$1"
    FOUND=$(wget -q -O - "$REPO/" 2>/dev/null | grep -o "href=\"${NAME}-[0-9].*\.apk\"" | head -1 | sed 's/href="//' | sed 's/"//')
    [ -z "$FOUND" ] && FOUND=$(wget -q -O - "$COMMUNITY/" 2>/dev/null | grep -o "href=\"${NAME}-[0-9].*\.apk\"" | head -1 | sed 's/href="//' | sed 's/"//')
    echo "$FOUND"
}

install_pkg() {
    PKG="$1"
    
    if ! echo "$PKG" | grep -q "\.apk$"; then
        FOUND=$(find_pkg "$PKG")
        [ -z "$FOUND" ] && echo "Not found: $PKG" && return 1
        PKG="$FOUND"
    fi
    
    echo "Installing ${PKG}..."
    mkdir -p "$PKG_DIR" /tmp/pkg
    
    URL="$REPO/${PKG}"
    wget -q -O "/tmp/${PKG}" "$URL" 2>/dev/null
    
    if [ ! -s "/tmp/${PKG}" ]; then
        URL="$COMMUNITY/${PKG}"
        wget -q -O "/tmp/${PKG}" "$URL" 2>/dev/null
    fi
    
    if [ -s "/tmp/${PKG}" ]; then
        # Save to disk
        cp "/tmp/${PKG}" "$PKG_DIR/${PKG}"
        
        # Extract and install
        cd /tmp/pkg
        tar -xzf "/tmp/${PKG}" 2>/dev/null
        cp -r usr/* /usr/ 2>/dev/null
        cp -r bin/* /bin/ 2>/dev/null
        cp -r sbin/* /sbin/ 2>/dev/null
        cp -r lib/* /lib/ 2>/dev/null
        cp -r etc/* /etc/ 2>/dev/null
        
        echo "${PKG}" >> "$PKG_DIR/installed.list"
        echo "Installed: ${PKG}"
        rm -rf /tmp/pkg/* /tmp/${PKG}
    else
        echo "Not found: ${PKG}"
    fi
}

search_pkg() {
    wget -q -O - "$REPO/" 2>/dev/null | grep -i "$1" | sed 's/.*href="//' | sed 's/".*//' | grep "\.apk$" | sort -u
    wget -q -O - "$COMMUNITY/" 2>/dev/null | grep -i "$1" | sed 's/.*href="//' | sed 's/".*//' | grep "\.apk$" | sort -u
}

case "$1" in
    install) [ -z "$2" ] && usage || install_pkg "$2" ;;
    search)  [ -z "$2" ] && usage || search_pkg "$2" ;;
    list)    cat "$PKG_DIR/installed.list" 2>/dev/null || echo "No packages" ;;
    *)       usage ;;
esac
