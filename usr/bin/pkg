#!/bin/sh
CACHE_DIR="/var/cache/pkg"
PKG_DIR="/mnt/disk/packages"
INSTALLED_LIST="$PKG_DIR/installed.list"
[ -d "$PKG_DIR" ] || INSTALLED_LIST="/var/log/installed.list"

ALPINE_VER="v3.20"
ARCH="x86_64"
REPO_MAIN="https://dl-cdn.alpinelinux.org/alpine/${ALPINE_VER}/main/${ARCH}"
REPO_COMMUNITY="https://dl-cdn.alpinelinux.org/alpine/${ALPINE_VER}/community/${ARCH}"

BLUE='\033[0;34m'
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

mkdir -p "$CACHE_DIR" /tmp/pkg 2>/dev/null

usage() {
    echo -e "${BLUE}=== RezzOS Package Manager (pkg) ===${NC}"
    echo "Usage:"
    echo "  pkg update                 - Refresh package indexes"
    echo "  pkg install <package>      - Install package"
    echo "  pkg search <query>         - Search for packages"
    echo "  pkg info <package>         - Show package details"
    echo "  pkg list                   - List installed packages"
    echo "  pkg remove <package>       - Remove package"
}

update_index() {
    echo -n "Fetching main index... "
    if wget -q --no-check-certificate "$REPO_MAIN/APKINDEX.tar.gz" -O "$CACHE_DIR/APKINDEX_main.tar.gz" 2>/dev/null; then
        tar -xzf "$CACHE_DIR/APKINDEX_main.tar.gz" -C "$CACHE_DIR" 2>/dev/null
        mv "$CACHE_DIR/APKINDEX" "$CACHE_DIR/APKINDEX_main" 2>/dev/null
        echo -e "${GREEN}OK${NC}"
    else
        echo -e "${RED}FAILED${NC}"
    fi

    echo -n "Fetching community index... "
    if wget -q --no-check-certificate "$REPO_COMMUNITY/APKINDEX.tar.gz" -O "$CACHE_DIR/APKINDEX_community.tar.gz" 2>/dev/null; then
        tar -xzf "$CACHE_DIR/APKINDEX_community.tar.gz" -C "$CACHE_DIR" 2>/dev/null
        mv "$CACHE_DIR/APKINDEX" "$CACHE_DIR/APKINDEX_community" 2>/dev/null
        echo -e "${GREEN}OK${NC}"
    else
        echo -e "${RED}FAILED${NC}"
    fi
}

search_pkg() {
    echo -e "${YELLOW}Searching for '$1'...${NC}"
    for idx in "$CACHE_DIR/APKINDEX_main" "$CACHE_DIR/APKINDEX_community"; do
        [ -f "$idx" ] || continue
        grep -i "P:$1" "$idx" | sed 's/P://'
    done
}

info_pkg() {
    NAME="$1"
    [ -z "$NAME" ] && echo "Specify package" && return 1
    for idx in "$CACHE_DIR/APKINDEX_main" "$CACHE_DIR/APKINDEX_community"; do
        [ -f "$idx" ] || continue
        grep -A10 "P:$NAME$" "$idx" | head -10
    done
}

find_pkg() {
    NAME="$1"
    for idx in "$CACHE_DIR/APKINDEX_main" "$CACHE_DIR/APKINDEX_community"; do
        [ -f "$idx" ] || continue
        VER=$(grep -A1 "P:$NAME$" "$idx" | grep "^V:" | head -1 | sed 's/V://')
        if [ -n "$VER" ]; then
            echo "${NAME}-${VER}.apk"
            return 0
        fi
    done
    return 1
}

install_pkg() {
    PKG="$1"
    [ -z "$PKG" ] && usage && return 1
    
    if echo "$PKG" | grep -q "\.apk$"; then
        APK="$PKG"
    else
        APK=$(find_pkg "$PKG")
    fi
    
    [ -z "$APK" ] && echo -e "${RED}Not found: $PKG${NC}" && return 1
    
    echo -e "${YELLOW}Installing $APK...${NC}"
    mkdir -p "$PKG_DIR" /tmp/pkg_dl
    
    wget -q --no-check-certificate "$REPO_MAIN/$APK" -O "/tmp/pkg_dl/$APK" 2>/dev/null || \
    wget -q --no-check-certificate "$REPO_COMMUNITY/$APK" -O "/tmp/pkg_dl/$APK" 2>/dev/null
    
    if [ ! -s "/tmp/pkg_dl/$APK" ]; then
        echo -e "${RED}Download failed${NC}"
        return 1
    fi
    
    cd /tmp && rm -rf /tmp/pkg_extract && mkdir -p /tmp/pkg_extract
    cd /tmp/pkg_extract
    tar -xzf "/tmp/pkg_dl/$APK" 2>/dev/null
    
    [ -d usr ] && cp -r usr/* /usr/ 2>/dev/null
    [ -d bin ] && cp -r bin/* /bin/ 2>/dev/null
    [ -d lib ] && cp -r lib/* /lib/ 2>/dev/null
    
    cp "/tmp/pkg_dl/$APK" "$PKG_DIR/"
    echo "$APK" >> "$INSTALLED_LIST"
    echo -e "${GREEN}Done: $APK${NC}"
}

remove_pkg() {
    PKG="$1"
    [ -z "$PKG" ] && echo "Specify package" && return 1
    
    if echo "$PKG" | grep -q "\.apk$"; then
        APK="$PKG"
    else
        APK=$(grep "^${PKG}-" "$INSTALLED_LIST" 2>/dev/null | head -1)
    fi
    
    [ -z "$APK" ] && echo -e "${RED}Not installed: $PKG${NC}" && return 1
    
    APK_FILE="$PKG_DIR/$APK"
    if [ ! -f "$APK_FILE" ]; then
        echo -e "${RED}Package file not found: $APK${NC}"
        sed -i "/^${APK}$/d" "$INSTALLED_LIST" 2>/dev/null
        return 1
    fi
    
    echo -e "${YELLOW}Removing $APK...${NC}"
    
    for file in $(tar -tzf "$APK_FILE" 2>/dev/null); do
        target="/$file"
        if [ -f "$target" ] || [ -L "$target" ]; then
            rm -f "$target"
        fi
    done
    
    rm -f "$APK_FILE"
    sed -i "/^${APK}$/d" "$INSTALLED_LIST" 2>/dev/null
    echo -e "${GREEN}Removed: $APK${NC}"
}

case "$1" in
    update)  update_index ;;
    install) install_pkg "$2" ;;
    search)  search_pkg "$2" ;;
    info)    info_pkg "$2" ;;
    list)    cat "$INSTALLED_LIST" 2>/dev/null || echo "No packages" ;;
    remove)  remove_pkg "$2" ;;
    *)       usage ;;
esac
