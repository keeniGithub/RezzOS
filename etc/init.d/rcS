#!/bin/sh
mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs dev /dev

hostname $(cat /etc/hostname 2>/dev/null || echo "rezzos")
source /etc/profile 2>/dev/null
echo 0 > /proc/sys/kernel/printk

ifconfig lo 127.0.0.1 up
ifconfig eth0 10.0.2.15 netmask 255.255.255.0 up
route add default gw 10.0.2.2
echo "nameserver 8.8.8.8" > /etc/resolv.conf
echo "nameserver 8.8.4.4" >> /etc/resolv.conf

mount /dev/vda /mnt/disk 2>/dev/null

if [ -d /mnt/disk/packages ]; then
    for pkg in /mnt/disk/packages/*.apk; do
        [ -f "$pkg" ] || continue
        cd /tmp/pkg
        tar -xzf "$pkg" 2>/dev/null
        cp -r usr/* /usr/ 2>/dev/null
        cp -r bin/* /bin/ 2>/dev/null
        cp -r lib/* /lib/ 2>/dev/null
        rm -rf /tmp/pkg/*
    done
    cd /
fi

clear
/usr/bin/fetch

if ping -c 1 8.8.8.8 > /dev/null 2>&1; then
    echo "  Status:   Online"
else
    echo "  Status:   Offline"
fi
echo ""

exec /bin/bash 2>/dev/null || setsid cttyhack sh
